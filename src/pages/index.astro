---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import Header from '../components/Header.astro';
import HeroVideo from '../components/HeroVideo.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import ZoneMap from '../components/ZoneMap.astro';
import Testimonials from '../components/Testimonials.astro';
import PartnersLogoGrid from '../components/PartnersLogoGrid.astro';
import Footer from '../components/Footer.astro';
import { nav } from '../data/nav';
import { withBase } from '../utils/paths';


const partners = [
  { name: 'Les Redoubstables', logo: '/images/partners/redoubstables.png', href: 'https://www.lesredoubstables.org/' },
  { name: 'Motion UP', logo: '/images/partners/motionup.png', href: 'https://motion-up.ch/' },
];

const steps = [
  { title: 'Diagnostiquer', text: 'Comprendre votre contexte et définir une cible claire.' },
  { title: 'Entraîner', text: 'Outiller, pratiquer, ajuster entre les séances.' },
  { title: 'Ancrer', text: 'Stabiliser et rendre autonome.' }
];

const testimonials = [
  { quote: "Julien est une personne très à l'écoute, il a d'excellents conseils et je peux lui faire confiance à 100%. De plus il m'aide à la gestion de stress et au manque de confiance en moi.", author: 'Ilan', role: 'Triathlète - Suisse' },
  { quote: "Cela fait 4 mois que je travaille avec Julien. A l'écoute et avec toujours des bonnes idées on avance bien. Depuis que je travaille avec lui c'est 7 essais et 7 matchs et le mental fait parti du résultat.", author: 'Elliot', role: 'Rugbyman - Oyonnax' },
  { quote: "Julien est un super coach ! Il m’aide beaucoup notamment pour mes compétitions et je vois déjà de l’évolution, de bon conseil, à l’écoute, disponible, je recommande Julien !", author: 'Julie', role: 'Équitation' }
];
---

<BaseLayout title="Julien Jeangirard — Préparation mentale, coaching de vie & entreprise"
  description="Coaching de vie, préparation mentale et coaching en entreprise — Pontarlier, Doubs & Suisse voisine. Contact et accompagnements sur mesure, présentiel & visio.">

  <SEO title="Julien Jeangirard — Préparation mentale, coaching de vie & entreprise"
       description="Révélez votre potentiel : sport, vie, entreprise. Présentiel Doubs & Suisse voisine, ou visio." />
  <SchemaOrg type="LocalBusiness" data={{
    name: 'Julien Jeangirard Coaching',
    areaServed: ['Pontarlier','Besançon','Lausanne','Morteau','Yverdon-les-Bains','Haut-Jura'],
    url: 'https://www.julienjeangirard-coaching.fr',
    image: '/images/og-image.jpg',
    address: { '@type':'PostalAddress', addressLocality:'Pontarlier', addressRegion:'Doubs', addressCountry:'FR' },
    telephone: '+33 6 81 88 30 09'
  }} />

  <Header links={nav} ctaLabel="Contact" ctaHref={withBase('contact')} transparentOnTop scrollScaleLogo={true} />

  <!-- HERO vidéo, texte condensé -->
  <HeroVideo
    eyebrow="Coaching humain & performance"
    title="Préparation mentale, coaching de vie & d’équipes"
    subline="Des outils concrets pour décider, agir et tenir dans la durée."
    primaryCta={{ label: 'Réserver un appel', href: withBase('/contact') }}
    secondaryCta={{ label: 'Découvrir les accompagnements', href: withBase('/#services') }}
    poster={withBase('/images/hero.jpg')}
    srcMp4={withBase('/videos/hero.mp4')}
    srcWebm={withBase('/videos/hero.webm')}
  />

  <!-- Aperçu Services (liens vers pages dédiées) -->
  <section id="services" class="container py-16">
    <hr class="h-px w-96 mt-8 mb-8 ml-auto mr-auto bg-[color:var(--accent)] border-0 dark:bg-[color:var(--accent)]"/>

    <SectionTitle title="Découvrez l’accompagnement qui vous correspond" subtitle="Des formats simples, adaptés à votre contexte." />

    <div class="mt-10 grid md:grid-cols-3 gap-6 mb-16">
      <article class="bg-surface/90 border border-white/15 rounded-xl p-6 text-left">
        <h3 class="text-xl font-semibold">Coaching de vie</h3>
        <p class="text-text-muted mt-2">Retrouver du sens, de la clarté, de la confiance. Reprendre votre place.</p>
        <a href={withBase('coaching-de-vie')} class="mt-4 inline-block text-[color:var(--accent)] hover:underline">En savoir plus →</a>
      </article>

      <article class="bg-surface/90 border border-white/15 rounded-xl p-6 text-left">
        <h3 class="text-xl font-semibold">Préparation mentale</h3>
        <p class="text-text-muted mt-2">Gérer la pression, rester lucide, performer sereinement (sportifs & artistes).</p>
        <a href={withBase('preparation-mentale')} class="mt-4 inline-block text-[color:var(--accent)] hover:underline">En savoir plus →</a>
      </article>

      <article class="bg-surface/90 border border-white/15 rounded-xl p-6 text-left">
        <h3 class="text-xl font-semibold">Coaching en entreprise</h3>
        <p class="text-text-muted mt-2">Cohésion, communication, motivation. Des comportements concrets au quotidien.</p>
        <a href={withBase('coaching-en-entreprise')} class="mt-4 inline-block text-[color:var(--accent)] hover:underline">En savoir plus →</a>
      </article>
    </div>
  </section>

  <section class="bg-[color:var(--accent)] text-black text-center py-6">
    <h3 class="text-3xl md:text-4xl font-semibold">Vous avez un objectif, un défi ou un changement en tête ?</h3>
    <p class="text-lg md:text-xl mt-2 opacity-90">Faisons le point ensemble — première prise de contact gratuite et sans engagement.</p>
    <a href={withBase("contact")} class="mt-8 inline-block rounded-lg px-8 py-4 bg-black text-[color:var(--accent)] font-semibold tracking-wide hover:opacity-90">
      Partagez votre besoin
    </a>
  </section>

  <!-- À propos condensé -->
  <section id="apropos" class="container py-16">
    <SectionTitle title="Ils me font confiance" subtitle="" />
    <PartnersLogoGrid partners={partners} />
    <p class="text-text-muted mt-6 text-center"><a class="underline" href={withBase('contact')}>Contactez-moi</a> pour en savoir plus.</p>
  </section>


  <!-- À propos condensé -->
  <section id="apropos" class="container py-16">
    <SectionTitle eyebrow="Ma philosophie" title="Une approche simple, ancrée dans le réel" subtitle="Écoute, clarté, résultats durables." />
    <ProcessSteps steps={steps} />
    <p class="text-text-muted mt-6 text-center">Découvrez <a class="underline" href={withBase('a-propos')}>mon parcours et mon profil</a>.</p>
  </section>

  <!-- Zone -->
  <section id="zone" class="container py-16">
    <SectionTitle eyebrow="Zone d’intervention" title="Doubs & Suisse voisine" subtitle="Présentiel & visio possibles." />
    <ZoneMap title="J’interviens ici :" areas={[
      'Pontarlier','Besançon','Lausanne','Morteau','Yverdon-les-Bains','Haut-Jura'
    ]} note="Déplacements possibles selon devis. Séances en visio disponibles en France et en Suisse." />
  </section>

  <!-- Témoignages -->
  <section id="temoignages" class="container py-16">
    <SectionTitle eyebrow="Témoignages" title="Ce que disent les clients" />
    <Testimonials items={testimonials} />
  </section>

  <!-- Contact -->
  <section id="contact" class="text-center container py-16">
    <SectionTitle eyebrow="🤝🏻" title="Parlons de votre objectif" subtitle="" />
    <p class="text-text-muted mb-6 text-center">
      Vous ne savez pas par où commencer ?<br/>
      Parlons ensemble de votre objectif et définissons un plan d'action sur mesure.
    </p>
    <a href={withBase('contact')} class="inline-flex items-center rounded-lg px-4 py-2 bg-[color:var(--accent)] text-black font-medium hover:opacity-90 focus-visible:outline-none">
      Contactez-moi !
    </a>
  </section>

  <Footer />
</BaseLayout>
