---
const address = "Pontarlier, Doubs · Interventions FR & CH · Visio";
const phones = ["+33 6 81 88 30 09", "+41 79 244 11 74"];
const email = "julien.jeangirard@gmail.com";
const social = [
  { label: "LinkedIn", href: "https://www.linkedin.com/in/julien-jeangirard-8a778485" },
  { label: "Instagram", href: "https://www.instagram.com/coaching_et_mental" },
  { label: "Facebook", href: "https://www.facebook.com/ju.jeangirard" },
];
const legalLinks = [
  { label: "Mentions légales", href: "#" },
  { label: "Politique de confidentialité", href: "#" },
];

import LogoJJ from "./LogoJJ.astro";
import { withBase } from '../utils/paths';
---

<footer
  class="bg-[color:var(--accent)] text-black mt-12 py-8 border-t border-black/10"
>
  <div class="container grid md:grid-cols-3 gap-8 text-sm">
    <!-- Bloc coordonnées -->
    <div>
      <h3 class="text-xl font-semibold mb-2">Julien Jeangirard Coaching</h3>
      {address && <p class="opacity-80">{address}</p>}
      {
        email && (
          <p class="mt-2">
            <a href={`mailto:${email}`} class="hover:underline font-medium">
              {email}
            </a>
          </p>
        )
      }
      {
        phones.length > 0 && (
          <ul class="mt-2 space-y-1">
            {phones.map((p) => (
              <li>
                <a href={`tel:${p}`} class="hover:underline">
                  {p}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <!-- Bloc réseaux sociaux -->
    <div class="flex flex-col items-center md:justify-center gap-4">
      <LogoJJ class="w-16 h-16" />
      <div class="flex flex-wrap justify-center gap-6">
        {
          social.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="transition-transform hover:scale-110"
              aria-label={s.label}
            >
              {s.label === "Facebook" && (
                <img
                  src={withBase('/social-fb.svg')}
                  alt="Facebook"
                  class="w-8 h-8"
                />
              )}
              {s.label === "Instagram" && (
                <img
                  src={withBase('/social-ig.svg')}
                  alt="Instagram"
                  class="w-8 h-8"
                />
              )}
              {s.label === "LinkedIn" && (
                <img
                  src={withBase('/social-li.svg')}
                  alt="LinkedIn"
                  class="w-8 h-8"
                />
              )}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Bloc mentions légales -->
    <div class="md:text-right space-y-1">
      {
        legalLinks.map((l) => (
          <p>
            <a href={l.href} class="hover:underline font-medium">
              {l.label}
            </a>
          </p>
        ))
      }
      <p class="text-xs opacity-80 mt-4">
        © {new Date().getFullYear()} Julien Jeangirard Coaching
      </p>
      <!-- <p class="text-xs text-text-muted">Crafted with ❤️ by <a href="https://onestepstudio.fr" target="_blank" rel="noopener">OneStepStudio</a></p> -->
    </div>
  </div>
</footer>
